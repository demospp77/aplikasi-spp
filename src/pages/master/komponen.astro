---
import AppLayout from "../../layouts/AppLayout.astro";
---

<AppLayout title="Master Komponen Biaya">
	<header class="mb-6">
		<p class="text-sm font-semibold uppercase tracking-[0.15em] text-[var(--brand)]">Master Data</p>
		<h2 class="text-2xl font-black sm:text-3xl">Komponen Biaya</h2>
	</header>

	<section class="grid gap-4 lg:grid-cols-[420px_1fr]">
		<form id="component-form" class="rounded-xl border border-slate-200 p-4">
			<h3 id="form-title" class="text-lg font-bold">Tambah Komponen</h3>
			<input type="hidden" id="edit-id" />
			<div class="mt-4 space-y-3">
				<input
					name="name"
					id="f-name"
					required
					placeholder="Nama komponen (contoh: SPP Bulanan)"
					class="w-full rounded-lg border border-slate-300 px-3 py-2"
				/>
				<select
					name="payment_type"
					id="f-payment-type"
					class="w-full rounded-lg border border-slate-300 px-3 py-2 bg-white"
				>
					<option value="cicil">Cicilan</option>
					<option value="tunai">Tunai</option>
				</select>
				<input
					name="default_amount"
					id="f-amount"
					type="number"
					min="0"
					step="1000"
					placeholder="Nominal default"
					class="w-full rounded-lg border border-slate-300 px-3 py-2"
				/>
			</div>
			<div class="mt-4 flex gap-2">
				<button
					type="submit"
					class="rounded-lg bg-[var(--brand)] px-4 py-2 font-semibold text-white"
				>
					Simpan
				</button>
				<button
					type="button"
					id="btn-cancel"
					class="hidden rounded-lg border border-slate-300 px-4 py-2 font-semibold"
				>
					Batal
				</button>
			</div>
		</form>

		<div class="rounded-xl border border-slate-200 p-4">
			<h3 class="text-lg font-bold">Daftar Komponen</h3>
			<div class="mt-3 overflow-x-auto">
				<table class="min-w-full text-sm">
					<thead class="border-b bg-slate-50 text-left text-xs uppercase text-slate-500">
						<tr>
							<th class="px-3 py-2">Nama</th>
							<th class="px-3 py-2">Tipe</th>
							<th class="px-3 py-2">Nominal Default</th>
							<th class="px-3 py-2">Status</th>
							<th class="px-3 py-2">Aksi</th>
						</tr>
					</thead>
					<tbody id="components-body"></tbody>
				</table>
			</div>
		</div>
	</section>

	<script>
		import { createClient } from "@supabase/supabase-js";

		const supabase = createClient(
			import.meta.env.PUBLIC_SUPABASE_URL,
			import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
		);
		const idr = new Intl.NumberFormat("id-ID", { style: "currency", currency: "IDR", maximumFractionDigits: 0 });

		const form = document.getElementById("component-form");
		const formTitle = document.getElementById("form-title");
		const editIdInput = document.getElementById("edit-id");
		const btnCancel = document.getElementById("btn-cancel");
		const body = document.getElementById("components-body");

		const TYPE_LABEL = { cicil: "Cicilan", tunai: "Tunai" };
		const componentMap = new Map();

		function resetForm() {
			form.reset();
			editIdInput.value = "";
			formTitle.textContent = "Tambah Komponen";
			btnCancel.classList.add("hidden");
		}

		async function loadData() {
			const { data, error } = await supabase
				.from("components")
				.select("id,name,payment_type,default_amount,is_active")
				.order("name");

			if (error) {
				body.innerHTML = `<tr><td class="px-3 py-3 text-red-600" colspan="5">${error.message}</td></tr>`;
				return;
			}

			componentMap.clear();
			(data || []).forEach((c) => componentMap.set(c.id, c));

			body.innerHTML = (data || [])
				.map(
					(item) => `<tr class="border-b">
						<td class="px-3 py-2 font-medium">${item.name}</td>
						<td class="px-3 py-2">${TYPE_LABEL[item.payment_type] ?? item.payment_type}</td>
						<td class="px-3 py-2">${idr.format(Number(item.default_amount || 0))}</td>
						<td class="px-3 py-2">
							<span class="rounded-full px-2 py-0.5 text-xs font-medium ${item.is_active ? "bg-green-100 text-green-700" : "bg-slate-100 text-slate-500"}">
								${item.is_active ? "Aktif" : "Nonaktif"}
							</span>
						</td>
						<td class="px-3 py-2 space-x-2 whitespace-nowrap">
							<button data-id="${item.id}" data-action="edit"
								class="text-blue-600 hover:underline text-xs">Edit</button>
							<button data-id="${item.id}" data-action="toggle"
								class="text-amber-600 hover:underline text-xs">
								${item.is_active ? "Nonaktifkan" : "Aktifkan"}
							</button>
							<button data-id="${item.id}" data-action="delete"
								class="text-red-600 hover:underline text-xs">Hapus</button>
						</td>
					</tr>`,
				)
				.join("");
		}

		body.addEventListener("click", async (e) => {
			const btn = e.target.closest("button[data-action]");
			if (!btn) return;
			const { id, action } = btn.dataset;
			const item = componentMap.get(id);
			if (!item) return;

			if (action === "edit") {
				formTitle.textContent = "Edit Komponen";
				editIdInput.value = item.id;
				document.getElementById("f-name").value = item.name;
				document.getElementById("f-payment-type").value = item.payment_type;
				document.getElementById("f-amount").value = String(item.default_amount || 0);
				btnCancel.classList.remove("hidden");
				window.scrollTo({ top: 0, behavior: "smooth" });
			}

			if (action === "toggle") {
				const { error } = await supabase
					.from("components")
					.update({ is_active: !item.is_active })
					.eq("id", id);
				if (error) return alert(error.message);
				await loadData();
			}

			if (action === "delete") {
				if (!confirm(`Hapus komponen "${item.name}"?`)) return;
				const { error } = await supabase.from("components").delete().eq("id", id);
				if (error) return alert(error.message);
				await loadData();
			}
		});

		btnCancel.addEventListener("click", resetForm);

		form.addEventListener("submit", async (e) => {
			e.preventDefault();
			const fd = new FormData(form);
			const isEdit = !!editIdInput.value;

			const payload = {
				name: fd.get("name"),
				payment_type: fd.get("payment_type"),
				default_amount: Number(fd.get("default_amount") || 0),
			};

			if (isEdit) {
				const { error } = await supabase.from("components").update(payload).eq("id", editIdInput.value);
				if (error) return alert(error.message);
			} else {
				const { error } = await supabase.from("components").insert(payload);
				if (error) return alert(error.message);
			}

			resetForm();
			await loadData();
		});

		await loadData();
	</script>
</AppLayout>
